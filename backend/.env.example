# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///nearby_care.db
# For PostgreSQL: postgresql://username:password@localhost:5432/nearby_care
# Note: SQLite will automatically create the database in instance/ folder

# Email Configuration (Gmail SMTP)
SMTP_SENDER=your-email@gmail.com
SMTP_APP_PASSWORD=your-app-password-here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Google Gemini AI
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Cohere AI
COHERE_API_KEY=your-cohere-api-key-here

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# OpenStreetMap Configuration
NOMINATIM_USER_AGENT=NearbyCareApp/1.0
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_CONTENT_LENGTH=16777216

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per hour
